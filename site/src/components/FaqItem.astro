---
/**
 * Single FAQ disclosure. Wrap a list of these in a plain <div>;
 * pass the answer as the default slot (HTML allowed).
 */
interface Props {
  question: string;
  /** Open by default (use sparingly, e.g. first item). */
  open?: boolean;
}

const { question, open = false } = Astro.props;
---

<details class="faq-item" open={open}>
  <summary>
    <span class="faq-question">{question}</span>
    <span class="faq-marker" aria-hidden="true"></span>
  </summary>
  <div class="faq-answer">
    <slot />
  </div>
</details>

<style>
  .faq-item {
    border-bottom: 1px solid var(--line);
  }

  summary {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.35rem 0.25rem;
    cursor: pointer;
    list-style: none;
    transition: color var(--transition);
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary:hover .faq-marker::before,
  summary:hover .faq-marker::after {
    transform: scale(1.35);
  }

  .faq-question {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 500;
    line-height: 1.3;
  }

  .faq-marker {
    flex-shrink: 0;
    position: relative;
    width: 0.9rem;
    height: 0.9rem;
    align-self: center;
  }

  .faq-marker::before,
  .faq-marker::after {
    content: '';
    position: absolute;
    inset: 0;
    margin: auto;
    background: var(--gold);
    transition: transform var(--transition);
  }

  .faq-marker::before {
    width: 100%;
    height: 1px;
  }

  .faq-marker::after {
    width: 1px;
    height: 100%;
  }

  .faq-item[open] .faq-marker::after {
    transform: rotate(90deg) scaleY(0);
  }

  .faq-answer {
    padding: 0 0.25rem 1.5rem;
    max-width: 60ch;
    color: var(--umber);
  }

  .faq-answer :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
