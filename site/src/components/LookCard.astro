---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { LOOK_CATEGORIES } from '../lib/looks';

interface Props {
  look: CollectionEntry<'looks'>;
  /** Pass true for above-the-fold cards. */
  eager?: boolean;
}

const { look, eager = false } = Astro.props;
const { title, image, imageAlt, teaser, category } = look.data;
const categoryLabel = LOOK_CATEGORIES[category];
---

<article class="look-card">
  <a class="look-card-link" href={`/looks/${look.id}`}>
    <div class="look-card-media">
      <Image
        src={image}
        alt={imageAlt}
        widths={[420, 640, 920]}
        sizes="(max-width: 700px) 92vw, 30vw"
        loading={eager ? 'eager' : 'lazy'}
      />
    </div>
    <div class="look-card-body">
      <p class="look-card-category">{categoryLabel}</p>
      <h3 class="look-card-title">{title}</h3>
      <p class="look-card-teaser">{teaser}</p>
      <span class="look-card-cta" aria-hidden="true">Shop the look →</span>
    </div>
  </a>
</article>

<style>
  .look-card {
    height: 100%;
  }

  .look-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    background: var(--card);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .look-card-link:hover {
    box-shadow: var(--shadow-lift);
    transform: translateY(-3px);
  }

  .look-card-media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--ivory);
  }

  .look-card-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.3, 0.6, 0.3, 1);
  }

  .look-card-link:hover .look-card-media :global(img) {
    transform: scale(1.03);
  }

  .look-card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.4rem 1.5rem 1.6rem;
  }

  .look-card-category {
    font-size: 0.72rem;
    font-weight: 570;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sage);
    margin: 0 0 0.55rem;
  }

  .look-card-title {
    font-size: 1.45rem;
    margin-bottom: 0.4rem;
  }

  .look-card-teaser {
    font-size: 0.95rem;
    color: var(--umber);
    margin-bottom: 1.1rem;
  }

  .look-card-cta {
    margin-top: auto;
    font-size: 0.8rem;
    font-weight: 560;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
  }
</style>
