---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { SITE } from '../lib/site';
import { getPublishedLooks } from '../lib/looks';

import avatarPhoto from '../assets/photos/flatlay-neutrals.jpg';

/** UTM tracking for everything leaving the bio hub. */
const UTM = 'utm_source=instagram&utm_medium=bio&utm_campaign=links';

const primaryLinks = [
  { label: 'Book a Style Conversation', href: `/book?${UTM}`, variant: 'btn--primary' },
  { label: 'Shop My Latest Looks', href: `/looks?${UTM}`, variant: 'btn--outline' },
  { label: 'Explore Styling Services', href: `/services?${UTM}`, variant: 'btn--outline' },
  { label: 'Get the Free Closet Reset', href: `/?${UTM}#closet-reset`, variant: 'btn--outline' },
] as const;

const latestLooks = (await getPublishedLooks()).slice(0, 3);
---

<Base
  title="Instagram Links"
  description="Susanne's link hub: book a complimentary style conversation, shop the latest looks, explore Chicago + virtual styling services, and grab the free Closet Reset."
  bare={true}
>
  <div class="links-page">
    <!-- ------------------------------------------------------- Identity -->
    <header class="links-header">
      <div class="links-avatar">
        <Image
          src={avatarPhoto}
          alt="Flatlay of neutral wardrobe pieces styled by Susanne."
          widths={[96, 192]}
          sizes="5.5rem"
          loading="eager"
        />
      </div>
      <h1 class="links-wordmark">
        Styled <span class="serif-italic links-by">by</span> Susanne
      </h1>
      <p class="links-bio">Personal styling · Chicago + virtual</p>
      <a class="links-handle" href={SITE.instagram} rel="noopener">
        {SITE.instagramHandle}
      </a>
    </header>

    <!-- -------------------------------------------------- Primary links -->
    <nav class="links-buttons" aria-label="Primary links">
      {
        primaryLinks.map((link) => (
          <a class:list={['btn', link.variant]} href={link.href}>
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- --------------------------------------------------- Latest looks -->
    {
      latestLooks.length > 0 && (
        <section class="links-looks" aria-label="Latest looks">
          <h2 class="links-looks-title">Latest looks</h2>
          <div class="links-looks-grid">
            {latestLooks.map((look) => (
              <a class="links-look" href={`/looks/${look.id}?${UTM}`}>
                <div class="links-look-media">
                  <Image
                    src={look.data.image}
                    alt={look.data.imageAlt}
                    widths={[160, 320]}
                    sizes="(max-width: 480px) 28vw, 7.5rem"
                    loading="lazy"
                  />
                </div>
                <span class="links-look-label">{look.data.title}</span>
              </a>
            ))}
          </div>
          <p class="links-disclosure">
            Look pages may contain affiliate links: <a
              href="/policies/affiliate-disclosure">how that works</a>.
          </p>
        </section>
      )
    }

    <!-- --------------------------------------------------------- Footer -->
    <footer class="links-footer">
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      <span aria-hidden="true">·</span>
      <a href="/">styledbysusanne.com</a>
    </footer>
  </div>
</Base>

<style>
  .links-page {
    width: min(100% - 2.5rem, 26rem);
    margin-inline: auto;
    padding-block: clamp(2.75rem, 8vw, 4.5rem) 2.75rem;
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
    text-align: center;
  }

  /* Identity */
  .links-avatar {
    width: 5.5rem;
    height: 5.5rem;
    margin: 0 auto 1.1rem;
    padding: 0.3rem;
    border: 1px solid var(--gold-hairline);
    border-radius: 50%;
  }

  .links-avatar :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .links-wordmark {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    margin: 0 0 0.3rem;
  }

  .links-by {
    color: var(--gold);
    font-weight: 400;
  }

  .links-bio {
    font-size: 0.9rem;
    color: var(--umber);
    letter-spacing: 0.02em;
    margin: 0 0 0.5rem;
  }

  .links-handle {
    font-size: 0.82rem;
    font-weight: 550;
    letter-spacing: 0.1em;
    text-decoration: none;
    color: var(--sage);
    border-bottom: 1px solid var(--gold-hairline);
    padding-bottom: 0.15rem;
  }

  .links-handle:hover {
    border-color: var(--gold);
  }

  /* Primary links */
  .links-buttons {
    display: grid;
    gap: 0.9rem;
  }

  .links-buttons .btn {
    width: 100%;
    padding: 1.05rem 1.5rem;
  }

  /* Latest looks */
  .links-looks-title {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 560;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--sage);
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 0 0 1.2rem;
  }

  .links-looks-title::before,
  .links-looks-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--line);
  }

  .links-looks-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.7rem;
  }

  .links-look {
    display: block;
    text-decoration: none;
  }

  .links-look-media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--line-soft);
    background: var(--ivory);
    box-shadow: var(--shadow-card);
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .links-look:hover .links-look-media {
    box-shadow: var(--shadow-lift);
    transform: translateY(-2px);
  }

  .links-look-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .links-look-label {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.72rem;
    line-height: 1.4;
    color: var(--umber);
  }

  .links-disclosure {
    font-size: 0.72rem;
    color: var(--umber);
    margin: 1.2rem 0 0;
  }

  /* Footer */
  .links-footer {
    font-size: 0.8rem;
    color: var(--umber);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--line);
  }

  .links-footer a {
    color: inherit;
  }
</style>
