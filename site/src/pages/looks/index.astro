---
import Base from '../../layouts/Base.astro';
import InstagramLookCard from '../../components/InstagramLookCard.astro';
import CtaBand from '../../components/CtaBand.astro';
import Sparkle from '../../components/Sparkle.astro';
import instagramCatalog from '../../data/instagram-posts.json';
import { LOOK_CATEGORIES, type LookCategory } from '../../lib/looks';

const instagramPosts = instagramCatalog.map((post) => ({
  ...post,
  category: post.category as LookCategory,
  kind: post.kind as 'post' | 'reel',
}));

/** Newest post with a full piece-by-piece shopping edit leads the page. */
const featuredPost = instagramPosts.find((post) => post.shopHref) ?? instagramPosts[0];
const gridPosts = instagramPosts.filter((post) => post !== featuredPost);

const gridCategories = (Object.keys(LOOK_CATEGORIES) as LookCategory[]).filter((category) =>
  gridPosts.some((post) => post.category === category),
);
const categoryCounts = Object.fromEntries(
  gridCategories.map((category) => [
    category,
    gridPosts.filter((post) => post.category === category).length,
  ]),
) as Record<LookCategory, number>;
const instagramMediaCount = instagramPosts.reduce((total, post) => total + post.media.length, 0);
---

<Base
  title="Shop the Looks"
  description="Browse Susanne's real outfits and styling notes: the complete Instagram lookbook, every carousel slide included, with piece-by-piece shopping edits on selected looks."
>
  <!-- ============================================================ Hero -->
  <section class="looks-hero bg-blush-wash">
    <Sparkle size={22} top="12%" right="7%" delay={0.5} />
    <Sparkle size={14} top="34%" right="14%" gold delay={1.7} />
    <div class="container">
      <p class="eyebrow">Shop the looks</p>
      <h1>Real outfits, from my closet to <em class="serif-italic">yours</em></h1>
      <p class="lede">
        Every look starts on @styled.by.susanne: a real day, a real outfit,
        and the styling note that made it work. Browse the whole feed here,
        swipe through every carousel slide, and find deeper shopping
        breakdowns on selected looks.
      </p>
      <p class="looks-disclosure">
        Honesty first: some of the product links on these pages are affiliate
        links, which means I may earn a small commission if you shop through
        them, at no extra cost to you. <a
          href="/policies/affiliate-disclosure">Here's exactly how that works</a>.
      </p>
    </div>
  </section>

  <!-- ==================================================== Featured edit -->
  <section class="section looks-featured" aria-labelledby="featured-heading">
    <div class="container">
      <div class="looks-featured-head">
        <p class="eyebrow" id="featured-heading">Fresh from the feed</p>
      </div>
      <InstagramLookCard post={featuredPost} eager variant="featured" />
    </div>
  </section>

  <!-- =============================================== Instagram lookbook -->
  <section class="section instagram-lookbook" id="instagram-lookbook">
    <div class="container">
      <div class="instagram-lookbook-head">
        <div>
          <p class="eyebrow">Every look from @styled.by.susanne</p>
          <h2>The complete Instagram <em class="serif-italic">lookbook</em></h2>
          <p class="lede">
            Every outfit post, caption, reel cover, and carousel slide lives
            here, easy to find long after it leaves the feed. Posts marked
            &ldquo;Shop this look&rdquo; have full piece-by-piece edits.
          </p>
        </div>
        <p class="instagram-lookbook-count">
          <strong>{instagramPosts.length}</strong> posts<br />
          <strong>{instagramMediaCount}</strong> visuals
        </p>
      </div>
    </div>

    <div class="lookbook-toolbar" data-lookbook-toolbar>
      <div class="container">
        <div
          class="filter-chips"
          role="group"
          aria-label="Filter looks by category"
          data-instagram-filter-bar
          hidden
        >
          <button class="filter-chip" type="button" data-instagram-filter="all" aria-pressed="true">
            All looks <span class="filter-chip-count">{gridPosts.length}</span>
          </button>
          {
            gridCategories.map((category) => (
              <button
                class="filter-chip"
                type="button"
                data-instagram-filter={category}
                aria-pressed="false"
              >
                {LOOK_CATEGORIES[category]}
                <span class="filter-chip-count">{categoryCounts[category]}</span>
              </button>
            ))
          }
        </div>
      </div>
    </div>

    <div class="container">
      <p class="visually-hidden" role="status" data-instagram-filter-status></p>

      <ul class="instagram-grid" role="list">
        {
          gridPosts.map((post, index) => (
            <li data-instagram-category={post.category}>
              <InstagramLookCard post={post} eager={index < 3} />
            </li>
          ))
        }
      </ul>

      <div class="lookbook-more">
        <button class="btn btn--outline" type="button" data-show-more hidden>
          Show more looks
        </button>
      </div>
    </div>
  </section>

  <!-- ============================================= From my closet to yours -->
  <section class="section section--ivory looks-outro">
    <div class="container container--narrow text-center">
      <p class="eyebrow eyebrow--center">Beyond the links</p>
      <h2>Want this taste applied to <em class="serif-italic">your</em> closet?</h2>
      <p class="lede looks-outro-lede">
        Shopping my looks is the free sample. The real magic is opening your
        own closet and finding outfits like these already built; that's what
        my styling services are for. And if you'd like pieces like these
        sourced for your life (not mine) all year round, that's literally the
        Digital Stylist's job.
      </p>
      <div class="looks-outro-actions">
        <a class="btn btn--primary" href="/services">Explore Styling Services</a>
        <a class="btn btn--outline" href="/services/ongoing-styling">Meet the Digital Stylist</a>
      </div>
    </div>
  </section>

  <CtaBand
    title="Let's find out what your version of these looks like"
    secondaryLabel="Browse Styling Services"
    secondaryHref="/services"
  />
</Base>

<script>
  // Progressive enhancement throughout: without JavaScript every post is
  // visible, captions expand natively, and carousels swipe via scroll-snap.

  /* ------------------------------- category filter + show-more batching */
  const BATCH = 12;
  const bar = document.querySelector<HTMLElement>('[data-instagram-filter-bar]');
  const items = Array.from(
    document.querySelectorAll<HTMLLIElement>('li[data-instagram-category]'),
  );
  const status = document.querySelector<HTMLElement>('[data-instagram-filter-status]');
  const moreButton = document.querySelector<HTMLButtonElement>('[data-show-more]');

  if (bar && items.length) {
    bar.hidden = false;
    const chips = Array.from(
      bar.querySelectorAll<HTMLButtonElement>('button[data-instagram-filter]'),
    );

    let activeFilter = 'all';
    let visibleCap = BATCH;

    const apply = () => {
      const matches = items.filter(
        (item) => activeFilter === 'all' || item.dataset.instagramCategory === activeFilter,
      );
      for (const item of items) item.hidden = true;
      matches.forEach((item, index) => {
        item.hidden = index >= visibleCap;
      });

      const shown = Math.min(visibleCap, matches.length);
      const remaining = matches.length - shown;
      if (status) {
        status.textContent = `Showing ${shown} of ${matches.length} looks`;
      }
      if (moreButton) {
        moreButton.hidden = remaining <= 0;
        moreButton.textContent = `Show ${Math.min(BATCH, remaining)} more looks (${remaining} left)`;
      }
    };

    for (const chip of chips) {
      chip.addEventListener('click', () => {
        activeFilter = chip.dataset.instagramFilter ?? 'all';
        visibleCap = BATCH;
        for (const candidate of chips) {
          candidate.setAttribute('aria-pressed', String(candidate === chip));
        }
        apply();
      });
    }

    moreButton?.addEventListener('click', () => {
      visibleCap += BATCH;
      apply();
    });

    apply();
  }

  /* --------------------------------------- swipeable carousel galleries */
  for (const gallery of document.querySelectorAll<HTMLElement>('[data-instagram-gallery]')) {
    const track = gallery.querySelector<HTMLElement>('[data-gallery-track]');
    if (!track || track.children.length < 2) continue;

    const slideCount = track.children.length;
    const previous = gallery.querySelector<HTMLButtonElement>('[data-gallery-previous]');
    const next = gallery.querySelector<HTMLButtonElement>('[data-gallery-next]');
    const count = gallery.querySelector<HTMLElement>('[data-gallery-count]');
    const dots = Array.from(gallery.querySelector<HTMLElement>('[data-gallery-dots]')?.children ?? []);

    let active = 0;
    const render = () => {
      if (previous) previous.disabled = active === 0;
      if (next) next.disabled = active === slideCount - 1;
      if (count) count.textContent = `${active + 1} / ${slideCount}`;
      dots.forEach((dot, index) => dot.classList.toggle('is-active', index === active));
    };

    const goTo = (index: number) => {
      const clamped = Math.min(slideCount - 1, Math.max(0, index));
      track.scrollTo({ left: clamped * track.clientWidth, behavior: 'smooth' });
    };

    previous?.addEventListener('click', () => goTo(active - 1));
    next?.addEventListener('click', () => goTo(active + 1));

    let settle = 0;
    track.addEventListener(
      'scroll',
      () => {
        window.clearTimeout(settle);
        settle = window.setTimeout(() => {
          const index = Math.round(track.scrollLeft / track.clientWidth);
          if (index !== active) {
            active = Math.min(slideCount - 1, Math.max(0, index));
            render();
          }
        }, 80);
      },
      { passive: true },
    );

    render();
  }
</script>

<style>
  /* Hero */
  .looks-hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3.5rem, 2.5rem + 3.5vw, 6rem) clamp(2rem, 1.5rem + 2vw, 3rem);
  }

  .looks-hero h1 {
    margin-bottom: 0.45em;
  }

  .looks-hero h1 em {
    color: var(--rose);
  }

  .looks-hero .lede {
    max-width: 44em;
  }

  .looks-disclosure {
    font-size: 0.85rem;
    color: var(--umber);
    max-width: 52em;
    margin: 1.4rem 0 0;
    padding-top: 1.1rem;
    border-top: 1px solid var(--gold-hairline);
  }

  /* Featured edit */
  .looks-featured {
    padding-block: clamp(2.5rem, 2rem + 2vw, 4rem);
  }

  .looks-featured-head {
    margin-bottom: 1.4rem;
  }

  /* Lookbook head */
  .instagram-lookbook {
    border-top: 1px solid var(--line-soft);
    padding-top: clamp(3rem, 2.4rem + 2vw, 5rem);
  }

  .instagram-lookbook-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: clamp(2rem, 5vw, 5rem);
    margin-bottom: 1.6rem;
  }

  .instagram-lookbook-head h2 em {
    color: var(--rose);
  }

  .instagram-lookbook-head .lede {
    max-width: 44rem;
    margin-bottom: 0;
  }

  .instagram-lookbook-count {
    min-width: 8.5rem;
    color: var(--umber);
    border-left: 1px solid var(--gold-hairline);
    padding-left: 1.25rem;
    margin: 0 0 0.2rem;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    line-height: 1.6;
    text-transform: uppercase;
  }

  .instagram-lookbook-count strong {
    color: var(--espresso);
    font-family: var(--font-serif);
    font-size: 1.7rem;
    font-weight: 500;
    letter-spacing: 0;
  }

  /* Sticky filter toolbar */
  .lookbook-toolbar {
    position: sticky;
    top: 4.35rem;
    z-index: 30;
    background: rgba(250, 246, 239, 0.93);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-block: 1px solid var(--line-soft);
    padding-block: 0.75rem;
    margin-bottom: 2.2rem;
  }

  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .filter-chips[hidden] {
    display: none;
  }

  .filter-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 2.75rem; /* 44px tap target */
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 550;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--rose);
    background: transparent;
    border: 1px solid var(--rose);
    border-radius: 999px;
    padding: 0.5rem 1.15rem;
    cursor: pointer;
    transition: background-color var(--transition), color var(--transition),
      border-color var(--transition), box-shadow var(--transition);
  }

  .filter-chip-count {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--rose-deep);
    background: var(--rose-soft);
    border-radius: 999px;
    padding: 0.12rem 0.5rem;
    transition: background-color var(--transition), color var(--transition);
  }

  .filter-chip:hover {
    color: var(--rose-deep);
    border-color: var(--rose-deep);
    background: var(--rose-tint);
  }

  .filter-chip[aria-pressed='true'] {
    background: var(--rose);
    border-color: var(--rose);
    color: #fffdf9;
  }

  .filter-chip[aria-pressed='true'] .filter-chip-count {
    background: rgba(255, 253, 249, 0.22);
    color: #fffdf9;
  }

  .filter-chip[aria-pressed='true']:hover {
    background: var(--rose-deep);
    border-color: var(--rose-deep);
  }

  /* Grid */
  .instagram-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.8rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .instagram-grid > li {
    content-visibility: auto;
    contain-intrinsic-size: auto 46rem;
  }

  .lookbook-more {
    display: flex;
    justify-content: center;
    margin-top: 2.6rem;
  }

  .lookbook-more .btn[hidden] {
    display: none;
  }

  /* Outro band */
  .looks-outro h2 em {
    color: var(--rose);
  }

  .looks-outro-lede {
    margin-inline: auto;
    margin-bottom: 2.2rem;
  }

  .looks-outro-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  /* Responsive */
  @media (max-width: 980px) {
    .instagram-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .instagram-lookbook-head {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .instagram-lookbook-count {
      border-left: 0;
      border-top: 1px solid var(--gold-hairline);
      padding: 1rem 0 0;
    }

    .instagram-grid {
      grid-template-columns: 1fr;
      max-width: 26rem;
      margin-inline: auto;
      gap: 1.5rem;
    }

    /* One swipeable row of chips, edge to edge, scrollbar hidden. */
    .filter-chips {
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      margin-inline: -1.25rem;
      padding-inline: 1.25rem;
      padding-block: 0.15rem;
    }

    .filter-chips::-webkit-scrollbar {
      display: none;
    }

    .filter-chips[hidden] {
      display: none;
    }

    .filter-chip {
      flex: 0 0 auto;
      scroll-snap-align: start;
    }
  }
</style>
