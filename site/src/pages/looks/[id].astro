---
import { Image } from 'astro:assets';
import { render, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import CtaBand from '../../components/CtaBand.astro';
import Sparkle from '../../components/Sparkle.astro';
import { getPublishedLooks, LOOK_CATEGORIES } from '../../lib/looks';

export async function getStaticPaths() {
  const looks = await getPublishedLooks();
  // Looks are sorted newest first; wrap around at both ends so browsing
  // never dead-ends.
  return looks.map((entry, i) => ({
    params: { id: entry.id },
    props: {
      entry,
      newer: looks[(i - 1 + looks.length) % looks.length],
      older: looks[(i + 1) % looks.length],
      newerWraps: i === 0,
      olderWraps: i === looks.length - 1,
    },
  }));
}

interface Props {
  entry: CollectionEntry<'looks'>;
  newer: CollectionEntry<'looks'>;
  older: CollectionEntry<'looks'>;
  newerWraps: boolean;
  olderWraps: boolean;
}

const { entry, newer, older, newerWraps, olderWraps } = Astro.props;
const { Content } = await render(entry);

const { title, date, category, image, imageAlt, teaser, whyItWorks, pieces, similar, service } =
  entry.data;

const categoryLabel = LOOK_CATEGORIES[category];
const dateLabel = date.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
});

/** Hide prev/next when there is only one published look. */
const hasNav = newer.id !== entry.id;

/** Sticky mobile CTA: promise shopping only when a piece actually links out. */
const hasShoppablePieces = pieces.some((piece) => piece.url);
const mobileCtaLabel = hasShoppablePieces ? 'Shop This Look ↓' : 'See the Pieces ↓';

const description = `${teaser} Shop the exact pieces and similar finds at every price point.`;
---

<Base title={title} description={description} ogImage={image.src}>
  <article class="section look">
    <div class="container look-grid">
      <!-- ==================================================== Sticky photo -->
      <div class="look-media">
        <Sparkle size={18} top="-1.5%" right="7%" delay={0.8} />
        <div class="arch-frame look-photo">
          <Image
            src={image}
            alt={imageAlt}
            widths={[480, 720, 1040]}
            sizes="(max-width: 940px) 92vw, 42vw"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>

      <!-- ========================================================= Content -->
      <div class="look-body">
        <header class="look-header">
          <p class="eyebrow">{categoryLabel} · {dateLabel}</p>
          <h1>{title}</h1>
          <p class="lede">{teaser}</p>
        </header>

        <div class="prose look-story">
          <Content />
        </div>

        <aside class="look-why card">
          <p class="look-why-label">Why this works</p>
          <p>{whyItWorks}</p>
        </aside>

        <p class="look-disclosure">
          Quick honesty note: the shopping links below may be affiliate
          links, which means I may earn a small commission if you buy through
          them, at no extra cost to you. <a
            href="/policies/affiliate-disclosure">Here's how that works</a>.
        </p>

        {
          pieces.length > 0 && (
            <section class="look-shop" aria-labelledby="exact-pieces">
              <h2 id="exact-pieces">Shop the exact pieces</h2>
              <ul class="piece-list" role="list">
                {pieces.map((piece) => (
                  <li class="piece" data-reveal>
                    {piece.url ? (
                      <a
                        class="piece-card piece-card--link"
                        href={piece.url}
                        target="_blank"
                        rel="nofollow sponsored noopener"
                      >
                        <span class="piece-label">{piece.label}</span>
                        {piece.source && <span class="piece-tag">{piece.source}</span>}
                        <span class="piece-arrow" aria-hidden="true">→</span>
                      </a>
                    ) : (
                      <div class="piece-card">
                        <span class="piece-label">{piece.label}</span>
                        {piece.source && <span class="piece-tag">{piece.source}</span>}
                        <span class="piece-soon">shoppable link coming soon</span>
                      </div>
                    )}
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        {
          similar.length > 0 && (
            <section class="look-shop" aria-labelledby="similar-pieces">
              <h2 id="similar-pieces">Similar at other price points</h2>
              <ul class="similar-list" role="list">
                {similar.map((item) => (
                  <li class="similar" data-reveal>
                    {item.url ? (
                      <a
                        class="piece-card piece-card--link piece-card--lite"
                        href={item.url}
                        target="_blank"
                        rel="nofollow sponsored noopener"
                      >
                        <span class="piece-main">
                          <span class="piece-label">{item.label}</span>
                          {item.note && <span class="similar-note">{item.note}</span>}
                        </span>
                        <span class="piece-arrow" aria-hidden="true">→</span>
                      </a>
                    ) : (
                      <div class="piece-card piece-card--lite">
                        <span class="piece-main">
                          <span class="piece-label">{item.label}</span>
                          {item.note && <span class="similar-note">{item.note}</span>}
                        </span>
                      </div>
                    )}
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        {
          service && (
            <aside class="look-service card">
              <Sparkle size={14} top="1rem" right="1rem" gold delay={1.4} />
              <p class="look-service-label">Make it yours</p>
              <p class="look-service-blurb">
                {service.blurb ??
                  `This exact styling need has a service built for it: ${service.label}.`}
              </p>
              <a class="btn btn--rose" href={service.href}>
                {service.label}
              </a>
            </aside>
          )
        }
      </div>
    </div>
  </article>

  <!-- ================================================== Prev / next looks -->
  {
    hasNav && (
      <nav class="look-nav section--ivory" aria-label="More looks">
        <div class="container">
          <div class="look-nav-head">
            <p class="eyebrow">Keep browsing</p>
            <a class="text-link" href="/looks">All looks</a>
          </div>
          <div class="look-nav-grid">
            <a class="look-nav-card card" href={`/looks/${newer.id}`}>
              <div class="look-nav-thumb">
                <Image
                  src={newer.data.image}
                  alt=""
                  widths={[160, 320]}
                  sizes="74px"
                  loading="lazy"
                />
              </div>
              <div>
                <p class="look-nav-dir">{newerWraps ? '← Back to the oldest look' : '← Newer look'}</p>
                <p class="look-nav-title">{newer.data.title}</p>
              </div>
            </a>
            <a class="look-nav-card look-nav-card--older card" href={`/looks/${older.id}`}>
              <div class="look-nav-thumb">
                <Image
                  src={older.data.image}
                  alt=""
                  widths={[160, 320]}
                  sizes="74px"
                  loading="lazy"
                />
              </div>
              <div>
                <p class="look-nav-dir">{olderWraps ? 'Back to the newest look →' : 'Older look →'}</p>
                <p class="look-nav-title">{older.data.title}</p>
              </div>
            </a>
          </div>
        </div>
      </nav>
    )
  }

  <EmailCapture
    id="save-this-look"
    title="Save looks like this"
    lede="Monthly outfit formulas and new shoppable looks, straight to your inbox, plus first access to new services."
  />

  <CtaBand
    title="Want outfits like this waiting in your own closet?"
    secondaryLabel="Browse All Looks"
    secondaryHref="/looks"
  />

  {
    pieces.length > 0 && (
      <div class="mobile-cta" data-mobile-cta>
        <a class="btn btn--rose" href="#exact-pieces">{mobileCtaLabel}</a>
      </div>
    )
  }
</Base>

<script>
  // Sticky shop bar, mobile only: slides in once the visitor has scrolled
  // past ~55% of the first viewport, slides away again near the top.
  // Progressive enhancement: without JS the bar simply never appears.
  const bar = document.querySelector<HTMLElement>('[data-mobile-cta]');

  if (bar) {
    const mq = window.matchMedia('(max-width: 900px)');
    const update = () => {
      const shown = mq.matches && window.scrollY > window.innerHeight * 0.55;
      bar.classList.toggle('is-shown', shown);
    };
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();
  }
</script>

<style>
  .look {
    padding-block: clamp(3rem, 2rem + 3.5vw, 5.5rem) var(--section-pad);
  }

  .look-grid {
    display: grid;
    grid-template-columns: 0.92fr 1.08fr;
    gap: clamp(2.5rem, 2rem + 3vw, 5rem);
    align-items: start;
  }

  .look-media {
    position: sticky;
    top: 6.5rem;
  }

  .look-photo {
    aspect-ratio: 4 / 5;
    box-shadow: var(--shadow-lift);
  }

  @media (min-width: 941px) {
    .look-photo {
      max-height: calc(100dvh - 8.5rem);
    }
  }

  /* Header */
  .look-header {
    padding-bottom: 1.6rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 1.8rem;
  }

  .look-header h1 {
    font-size: clamp(2.2rem, 1.6rem + 2.4vw, 3.4rem);
    margin-bottom: 0.4em;
  }

  .look-header .lede {
    margin-bottom: 0;
  }

  /* Why this works: same idiom as the homepage featured look */
  .look-why {
    padding: 1.4rem 1.6rem;
    margin: 2rem 0;
    border-left: 2px solid var(--gold);
  }

  .look-why-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold-deep);
    margin-bottom: 0.4rem;
  }

  .look-why p:last-child {
    margin: 0;
    font-size: 0.98rem;
  }

  /* Affiliate disclosure, kept immediately above the shopping lists */
  .look-disclosure {
    font-size: 0.85rem;
    color: var(--umber);
    background: var(--ivory);
    border-radius: var(--radius);
    padding: 0.95rem 1.2rem;
    margin: 0 0 0.6rem;
  }

  /* Shopping lists */
  .look-shop {
    margin-top: 2.2rem;
    padding-top: 1.8rem;
    border-top: 1px solid var(--line);
  }

  .look-shop h2 {
    font-size: 1.7rem;
    margin-bottom: 0.8rem;
  }

  .piece-list,
  .similar-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  /* Tappable product card-pills: the whole row is the affiliate link. */
  .piece-card {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem 0.9rem;
    width: 100%;
    padding: 0.9rem;
    background: var(--card);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius);
  }

  a.piece-card {
    text-decoration: none;
    box-shadow: var(--shadow-card);
    transition: border-color var(--transition), box-shadow var(--transition),
      transform var(--transition);
  }

  a.piece-card:hover,
  a.piece-card:focus-visible {
    border-color: var(--blush);
    box-shadow: var(--shadow-lift);
    transform: translateY(-2px);
  }

  .piece-label {
    flex: 1 1 12ch;
    min-width: 0;
    color: var(--espresso);
    font-weight: 480;
    line-height: 1.45;
  }

  .piece-tag {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rose-deep);
    background: var(--rose-soft);
    border-radius: 999px;
    padding: 0.28rem 0.7rem;
    white-space: nowrap;
  }

  .piece-arrow {
    color: var(--rose);
    font-size: 1.05rem;
    line-height: 1;
    transition: transform var(--transition);
  }

  a.piece-card:hover .piece-arrow,
  a.piece-card:focus-visible .piece-arrow {
    transform: translateX(4px);
  }

  .piece-soon {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.92rem;
    color: var(--umber);
  }

  /* Similar finds: same shape, lighter weight. */
  .piece-card--lite {
    padding: 0.8rem 0.9rem;
  }

  a.piece-card--lite {
    box-shadow: none;
  }

  a.piece-card--lite:hover,
  a.piece-card--lite:focus-visible {
    box-shadow: var(--shadow-card);
    transform: translateY(-1px);
  }

  .piece-main {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    flex: 1 1 12ch;
    min-width: 0;
  }

  .similar-note {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.98rem;
    color: var(--umber);
    margin: 0;
  }

  /* Make it yours */
  .look-service {
    position: relative;
    padding: 1.8rem;
    margin-top: 2.6rem;
    background: var(--rose-soft);
    border: 1px solid var(--blush);
  }

  .look-service-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rose-deep);
    margin-bottom: 0.5rem;
  }

  .look-service-blurb {
    font-size: 0.98rem;
    color: var(--umber);
    margin-bottom: 1.3rem;
    max-width: 46ch;
  }

  /* Prev / next */
  .look-nav {
    padding-block: clamp(2.5rem, 2rem + 2vw, 4rem);
  }

  .look-nav-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.6rem;
  }

  .look-nav-head .eyebrow {
    margin-bottom: 0;
  }

  .look-nav-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.4rem;
  }

  .look-nav-card {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 1rem 1.2rem;
    text-decoration: none;
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .look-nav-card:hover {
    box-shadow: var(--shadow-lift);
    transform: translateY(-2px);
  }

  .look-nav-card--older {
    flex-direction: row-reverse;
    text-align: right;
  }

  .look-nav-thumb {
    width: 4.6rem;
    flex-shrink: 0;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-arch);
    overflow: hidden;
    background: var(--ivory);
  }

  .look-nav-thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .look-nav-dir {
    font-size: 0.7rem;
    font-weight: 570;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rose);
    margin: 0 0 0.3rem;
  }

  .look-nav-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    line-height: 1.25;
    margin: 0;
  }

  /* Sticky mobile shop bar (hidden on desktop, JS slides it in on scroll) */
  .mobile-cta {
    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 40;
    padding: 0.7rem 1rem calc(0.7rem + env(safe-area-inset-bottom));
    background: rgba(250, 246, 239, 0.94);
    backdrop-filter: blur(10px);
    border-top: 1px solid var(--line);
    display: none;
  }

  .mobile-cta .btn {
    width: 100%;
  }

  @media (max-width: 900px) {
    .mobile-cta {
      display: block;
      transform: translateY(100%);
      opacity: 0;
      transition: transform var(--transition), opacity var(--transition);
    }

    .mobile-cta.is-shown {
      transform: translateY(0);
      opacity: 1;
    }

    /* Keep the closing band's buttons clear of the fixed bar. */
    :global(.cta-band) {
      margin-bottom: 4.5rem;
    }
  }

  /* Responsive */
  @media (max-width: 940px) {
    .look-grid {
      grid-template-columns: 1fr;
    }

    /* Relative (not static) so the decorative sparkle stays anchored. */
    .look-media {
      position: relative;
      top: 0;
      max-width: 26rem;
      margin-inline: auto;
      width: 100%;
    }

    .look-nav-grid {
      grid-template-columns: 1fr;
    }

    .look-nav-card--older {
      flex-direction: row;
      text-align: left;
    }
  }
</style>
