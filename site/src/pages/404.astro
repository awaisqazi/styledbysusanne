---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found"
  description="This page didn't make the keep pile. Head back to the homepage, browse the latest shoppable looks, or book a complimentary style conversation."
  noindex
>
  <section class="section not-found">
    <div class="container container--narrow text-center">
      <p class="eyebrow eyebrow--center">Page not found</p>
      <h1>This page didn&rsquo;t make the <em class="serif-italic">keep</em> pile.</h1>
      <p class="lede not-found-lede">
        Either the link changed, or this page got donated in the last closet
        edit. (Occupational hazard: I edit everything.)
      </p>
      <div class="not-found-actions">
        <a class="btn btn--primary" href="/">Back to the Homepage</a>
        <a class="btn btn--outline" href="/looks">Shop the Looks</a>
      </div>
      <p class="not-found-book">
        <a class="text-link" href="/book">Or book a style conversation</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .not-found {
    padding-block: clamp(6rem, 4rem + 8vw, 11rem);
  }

  .not-found h1 em {
    color: var(--gold);
  }

  .not-found-lede {
    margin-inline: auto;
    margin-bottom: 2.4rem;
  }

  .not-found-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .not-found-book {
    margin: 2.4rem 0 0;
  }
</style>
