---
/**
 * Style note detail page.
 *
 * Uses Base directly (not the Prose layout): the page needs a "Keep
 * reading" block and a full-width CtaBand after the article, and Prose
 * only exposes a single slot inside its narrow .prose column. The header
 * markup below mirrors Prose.astro so the typography stays identical.
 */
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CtaBand from '../../components/CtaBand.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<'notes'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const otherNotes = (await getCollection('notes', ({ data }) => !data.draft))
  .filter((note) => note.id !== entry.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date): string =>
  date.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  });
---

<Base title={entry.data.title} description={entry.data.description}>
  <article class="section">
    <div class="container container--narrow">
      <header class="note-header">
        <p class="eyebrow">Style notes</p>
        <h1>{entry.data.title}</h1>
        <p class="note-dateline">{formatDate(entry.data.date)}</p>
      </header>
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>

  <section class="section section--ivory keep-reading">
    <div class="container container--narrow">
      <p class="eyebrow">Keep reading</p>
      {
        otherNotes.length > 0 ? (
          <div class="keep-reading-list">
            {otherNotes.map((note) => (
              <a class="keep-reading-item" href={`/style-notes/${note.id}`}>
                <p class="keep-reading-date">{formatDate(note.data.date)}</p>
                <h2 class="keep-reading-title">{note.data.title}</h2>
                <p class="keep-reading-desc">{note.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="keep-reading-empty">
            More notes are on the way, one principle at a time.
          </p>
        )
      }
      <p class="keep-reading-all">
        <a class="text-link" href="/style-notes">All style notes</a>
      </p>
    </div>
  </section>

  <CtaBand
    title="Want these principles applied to your closet?"
    lede="Notes are the theory. The practice is me, in your closet, making the decisions with you, and it always starts with a complimentary 30-minute style conversation."
    secondaryLabel="Explore Services"
    secondaryHref="/services"
  />
</Base>

<style>
  .note-header {
    margin-bottom: clamp(2rem, 1.5rem + 2vw, 3.2rem);
    padding-bottom: 1.8rem;
    border-bottom: 1px solid var(--line);
  }

  .note-header h1 {
    font-size: clamp(2.2rem, 1.6rem + 2.4vw, 3.4rem);
    margin-bottom: 0.35em;
  }

  .note-dateline {
    font-size: 0.85rem;
    color: var(--umber);
    margin: 0.6rem 0 0;
  }

  .keep-reading-list {
    display: grid;
    gap: 1.4rem;
  }

  .keep-reading-item {
    display: block;
    background: var(--card);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    padding: 1.8rem 2rem;
    text-decoration: none;
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .keep-reading-item:hover {
    box-shadow: var(--shadow-lift);
    transform: translateY(-2px);
  }

  .keep-reading-date {
    font-size: 0.75rem;
    font-weight: 550;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--umber);
    margin-bottom: 0.5rem;
  }

  .keep-reading-title {
    font-size: 1.5rem;
    margin-bottom: 0.3em;
    transition: color var(--transition);
  }

  .keep-reading-item:hover .keep-reading-title {
    color: var(--gold);
  }

  .keep-reading-desc {
    font-size: 0.95rem;
    color: var(--umber);
    margin: 0;
    max-width: 54ch;
  }

  .keep-reading-empty {
    color: var(--umber);
    margin: 0;
  }

  .keep-reading-all {
    margin: 2.2rem 0 0;
  }
</style>
