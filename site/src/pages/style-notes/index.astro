---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import CtaBand from '../../components/CtaBand.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const formatDate = (date: Date): string =>
  date.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  });
---

<Base
  title="Style Notes"
  description="Short, practical styling lessons from personal stylist Susanne Faris: one closet-tested principle per note, from color rules to closet edits."
>
  <section class="section notes-page">
    <div class="container container--narrow">
      <header class="notes-header">
        <p class="eyebrow">Style notes</p>
        <h1>One principle at a <em class="serif-italic">time</em></h1>
        <p class="lede">
          Short, practical styling lessons: the kind I teach standing in real
          closets. No trend reports, no twenty-item lists. One idea per note,
          each one usable tomorrow morning.
        </p>
      </header>

      <div class="notes-list">
        {
          notes.map((note) => (
            <article class="note-row">
              <p class="note-date">{formatDate(note.data.date)}</p>
              <div class="note-body">
                <h2 class="note-title">
                  <a href={`/style-notes/${note.id}`}>{note.data.title}</a>
                </h2>
                <p class="note-desc">{note.data.description}</p>
                <a class="text-link" href={`/style-notes/${note.id}`}>
                  Read the note
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <EmailCapture
    title="Get the next note first"
    lede="One short styling lesson at a time, straight to your inbox, plus first access to the free 15-Minute Closet Reset when the studio list opens."
  />

  <CtaBand
    title="Let&rsquo;s put these principles to work in your actual closet"
    lede="Reading about style is free. Having it decided for you is even better. Every engagement starts with a complimentary 30-minute style conversation."
    secondaryLabel="Explore Services"
    secondaryHref="/services"
  />
</Base>

<style>
  .notes-header {
    padding-bottom: clamp(1.8rem, 1.4rem + 1.5vw, 2.8rem);
    border-bottom: 1px solid var(--line);
  }

  .notes-header h1 {
    font-size: clamp(2.2rem, 1.6rem + 2.4vw, 3.4rem);
    margin-bottom: 0.35em;
  }

  .notes-header h1 em {
    color: var(--gold);
  }

  .notes-header .lede {
    margin-bottom: 0;
  }

  .note-row {
    display: grid;
    grid-template-columns: 10.5rem 1fr;
    gap: clamp(1.2rem, 1rem + 1.5vw, 2.6rem);
    padding-block: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    border-bottom: 1px solid var(--line);
  }

  .note-date {
    font-size: 0.78rem;
    font-weight: 550;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--umber);
    margin: 0.45rem 0 0;
  }

  .note-title {
    font-size: clamp(1.55rem, 1.3rem + 1vw, 2.05rem);
    margin-bottom: 0.35em;
  }

  .note-title a {
    text-decoration: none;
    transition: color var(--transition);
  }

  .note-title a:hover {
    color: var(--gold);
  }

  .note-desc {
    color: var(--umber);
    max-width: 54ch;
    margin-bottom: 1.3em;
  }

  @media (max-width: 640px) {
    .note-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .note-date {
      margin-top: 0;
    }
  }
</style>
