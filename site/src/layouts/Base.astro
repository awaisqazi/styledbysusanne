---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, DEFAULT_OG_IMAGE } from '../lib/site';

interface Props {
  title: string;
  description?: string;
  /** Absolute or root-relative path to a social share image. */
  ogImage?: string;
  /** Hide the standard header/footer (used by the /links bio hub). */
  bare?: boolean;
  /** Extra JSON-LD structured data for this page. */
  schema?: Record<string, unknown>;
  /** Emit a robots noindex tag and suppress canonical/og:url (error pages). */
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  ogImage = DEFAULT_OG_IMAGE,
  bare = false,
  schema,
  noindex = false,
} = Astro.props;

const fullTitle =
  title === SITE.name ? `${SITE.name}: Personal Stylist, Chicago` : `${title} · ${SITE.name}`;
// With build.format 'file' the build-time pathname is "/about.html";
// canonicals use the clean no-slash URL form served by the host.
const cleanPath =
  Astro.url.pathname.replace(/index\.html$/, '').replace(/\.html$/, '').replace(/\/+$/, '') || '/';
const canonical = new URL(cleanPath, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {!noindex && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    {!noindex && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="theme-color" content="#faf6ef" />
    {
      schema && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(schema)}
        />
      )
    }
    <script is:inline>
      // Motion styles are gated behind this class so no-JS visitors always
      // see full content (see "motion & decor" in global.css).
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    {!bare && <Header />}
    <main id="main">
      <slot />
    </main>
    {!bare && <Footer />}
    <script>
      // Scroll-reveal: soft rise-in for cards and section intros, staggered
      // among siblings. Script signatures wipe in via .signature-reveal.
      const AUTO =
        '.section-intro, .card, .look-card, .family-card, .standard-step, .outcome, .faq-item, [data-reveal]';

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const signatures = [...document.querySelectorAll('.signature-reveal')];
      const targets = [...document.querySelectorAll(AUTO)];

      if (!reduced && 'IntersectionObserver' in window) {
        const byParent = new Map<Element | null, number>();
        for (const el of targets) {
          const n = byParent.get(el.parentElement) ?? 0;
          (el as HTMLElement).style.setProperty('--reveal-delay', String(Math.min(n, 5)));
          byParent.set(el.parentElement, n + 1);
          el.classList.add('reveal');
        }
        // Safety net: if an environment stalls transition timelines (some
        // webviews and capture tools), hard-set the final state after the
        // longest possible transition (750ms + 450ms stagger) has elapsed.
        const finalize = (el: Element) => {
          window.setTimeout(() => {
            const s = (el as HTMLElement).style;
            s.transition = 'none';
            s.opacity = '1';
            s.translate = 'none';
            s.clipPath = 'none';
          }, 1700);
        };
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                finalize(e.target);
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
        );
        for (const el of [...targets, ...signatures]) io.observe(el);
      } else {
        for (const el of [...targets, ...signatures]) el.classList.add('is-visible');
      }
    </script>
  </body>
</html>
