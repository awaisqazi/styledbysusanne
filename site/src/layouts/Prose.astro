---
/**
 * Narrow-measure text page (policies, style notes, simple info pages).
 * Slot in markdown-rendered content or plain HTML; typography comes from
 * the global .prose styles.
 */
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  /** Optional intro line rendered under the H1. */
  intro?: string;
  /** Optional dateline (e.g. "Last updated July 18, 2026"). */
  dateline?: string;
}

const { title, description, eyebrow, intro, dateline } = Astro.props;
---

<Base title={title} description={description}>
  <article class="section">
    <div class="container container--narrow">
      <header class="prose-header">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <h1>{title}</h1>
        {intro && <p class="lede">{intro}</p>}
        {dateline && <p class="prose-dateline">{dateline}</p>}
      </header>
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</Base>

<style>
  .prose-header {
    margin-bottom: clamp(2rem, 1.5rem + 2vw, 3.2rem);
    padding-bottom: 1.8rem;
    border-bottom: 1px solid var(--line);
  }

  .prose-header h1 {
    font-size: clamp(2.2rem, 1.6rem + 2.4vw, 3.4rem);
    margin-bottom: 0.35em;
  }

  .prose-dateline {
    font-size: 0.85rem;
    color: var(--umber);
    margin: 0.6rem 0 0;
  }
</style>
